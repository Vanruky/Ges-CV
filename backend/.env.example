# Copia este archivo a .env y llena los valores reales antes de ejecutar el backend

# JWT secret para firmar/verificar tokens
JWT_SECRET=tu_secreto_jwt_aqui

# Configuración de la base de datos MySQL
DB_HOST=localhost
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_mysql
DB_NAME=ges_cv_db
DB_PORT=3306

# Puerto del servidor
PORT=3000
